{
    "version": "2.0",
    "envId": "dev-4gs517j09b896e44",
    "functionRoot": "cloudfunctions",
    "functions": [
    {
      "name": "get-family-info",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "获取家庭信息"
    },
    {
      "name": "create-family",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "创建家庭"
    },
    {
      "name": "join-family",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "加入家庭"
    },
    {
      "name": "wechat-login",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "微信登录"
    },
    {
      "name": "get-user-info",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "用openId数组获取用户信息"
    },
    {
      "name": "update-user-info",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "更新用户头像和昵称"
    },
    {
      "name": "logout",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "退出登录"
    },
    {
      "name": "get-family-info-by-id",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "通过familyId获取家庭信息"
    },
    {
      "name": "create-recipe",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "创建菜谱并关联到家庭"
    },
    {
      "name": "update-recipe",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "更新菜谱"
    },
    {
      "name": "delete-recipe",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "删除菜谱并从家庭 recipes 移除"
    },
    {
      "name": "get-recipes",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "获取家庭所有菜谱"
    },
    {
      "name": "create-or-update-daily-menu",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "创建或更新每日菜单"
    },
    {
      "name": "clean-expired-daily-menu",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "定时清理过期每日菜单",
      "triggers": [
        {
          "name": "cleanExpiredDailyMenuTimer",
          "type": "timer",
          "config": "0 0 * * * *"
        }
      ]  
    },
    {
      "name": "get-family-daily-menus",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "获取家庭所有每日菜单"
    },
    {
      "name": "get-family-daily-menu-by-date",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
      "description": "获取家庭某天每日菜单"
    },
    {
      "name": "remove-recipe-from-menu",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "installDependency": true,
      "timeout": 20,
      "memorySize": 256,
